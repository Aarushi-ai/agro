# ═══════════════════════════════════════════════════════════════════
# AGRO — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials
# This file should NOT be committed to version control (.env is in .gitignore)

# ─ EMAILJS CONFIGURATION ────────────────────────────────────────────
# EmailJS enables email notifications from contact/enquiry/complaint forms
# Get these credentials from https://www.emailjs.com/

# Your EmailJS Public Key (find in EmailJS dashboard > Account > Public Key)
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# Your EmailJS Service ID (find in EmailJS dashboard > Email Services)
EMAILJS_SERVICE_ID=your_service_id_here

# EmailJS Template ID for contact form messages
EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id_here

# EmailJS Template ID for product enquiry messages
EMAILJS_ENQUIRY_TEMPLATE_ID=your_enquiry_template_id_here

# EmailJS Template ID for complaint messages
EMAILJS_COMPLAINT_TEMPLATE_ID=your_complaint_template_id_here

# ─ WHATSAPP CONFIGURATION ───────────────────────────────────────────
# Used for WhatsApp contact links in forms and website
# Replace with your company WhatsApp number (include country code)
COMPANY_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ─ COMPANY EMAIL ────────────────────────────────────────────────────
# Email address where form submissions will be sent
COMPANY_EMAIL=info@agrocompany.in

# ─ ANALYTICS (Optional) ─────────────────────────────────────────────
# Google Analytics or other tracking IDs
GOOGLE_ANALYTICS_ID=your_ga_id_here

# ═══════════════════════════════════════════════════════════════════
# HOW TO USE:
# ═══════════════════════════════════════════════════════════════════
#
# 1. EMAILJS SETUP:
#    a) Create a free account at https://www.emailjs.com
#    b) Add an Email Service (Gmail, Outlook, or any SMTP provider)
#    c) Create 3 Email Templates:
#       - Contact Form Template
#       - Product Enquiry Template
#       - Complaint Form Template
#    d) Copy your Public Key, Service ID, and Template IDs below
#
# 2. EMAIL TEMPLATES SHOULD INCLUDE:
#    - {{from_name}}: Sender's name
#    - {{phone}}: Sender's phone number
#    - {{from_email}}: Sender's email
#    - {{subject}}: Message subject
#    - {{message}}: Message content
#    - {{product}}: Product interest (for enquiry)
#    - {{complaint_category}}: Complaint type (for complaints)
#    - {{order_id}}: Order reference (for complaints)
#
# 3. UPDATE CODE:
#    Replace placeholders in HTML/JS files:
#    - index.html: Replace "YOUR_EMAILJS_PUBLIC_KEY" in main.js init
#    - index.html, enquiry.html, complaint.html: Update form handlers
#    - Use: emailjs.init("YOUR_EMAILJS_PUBLIC_KEY")
#    - Use: emailjs.send("SERVICE_ID", "TEMPLATE_ID", templateParams)
#
# 4. WHATSAPP INTEGRATION:
#    - Format: https://wa.me/+91XXXXXXXXXX?text=Message
#    - Replace +91XXXXXXXXXX with your company's WhatsApp number
#    - Update all WhatsApp links in index.html, enquiry.html, complaint.html
#
# ═══════════════════════════════════════════════════════════════════

# AI Categorization — Groq (free forever, console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key_here

# WhatsApp via Twilio (twilio.com — free trial available)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
COMPANY_WHATSAPP_NUMBER=+919427205179
